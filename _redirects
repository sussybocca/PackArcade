# Custom error pages – Netlify will serve these HTML files for the respective HTTP status codes
/404.html   404
/403.html   403
/500.html   500

# Language detection for root – redirect based on Accept-Language header
# Order matters: put higher priority languages first.
/            /es/         302  Language=es
/            /fr/         302  Language=fr
/            /en/         302   # fallback (no condition)

# Optional: if you need to support clean URLs (e.g., /en/page without .html),
# uncomment the following lines to rewrite requests to the actual files.
# /en/*        /en/:splat   200
# /es/*        /es/:splat   200
# /fr/*        /fr/:splat   200

# Example: permanent redirects for old URLs (uncomment and adjust as needed)
# /old-blog/*  /news/:splat  301
